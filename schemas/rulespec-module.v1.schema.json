{
  "$id": "https://schemas.axiom-foundation.org/rules-engine/rulespec-module.v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": true,
  "allOf": [
    {
      "not": {
        "required": [
          "extends"
        ]
      }
    },
    {
      "not": {
        "required": [
          "schema"
        ]
      }
    }
  ],
  "description": "A RuleSpec module: `format: rulespec/v1` metadata, imports, units, and effective-dated rules (parameters, derived outputs, data/derived relations, and source-relation provenance edges).",
  "properties": {
    "format": {
      "const": "rulespec/v1",
      "description": "Exact RuleSpec format discriminator.",
      "type": "string"
    },
    "imports": {
      "items": {
        "not": {
          "pattern": "\\.(?:[Yy][Aa][Mm][Ll]|[Yy][Mm][Ll])(?:#|$)"
        },
        "pattern": "^[a-z]{2}(?:-[a-z0-9]+)*:(?:legislation|policies|regulations|statutes)/(?:[A-Za-z0-9_.~-]+/)*[A-Za-z0-9_.~-]+(?:#[A-Za-z0-9_.-]+)?$",
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "module": {
      "additionalProperties": true,
      "description": "Descriptive, inert module metadata. Never affects lowering, compilation, or execution.",
      "not": {
        "required": [
          "id"
        ]
      },
      "properties": {
        "encoding_provenance": {
          "additionalProperties": false,
          "description": "Who/what produced the encoding. Unknown subfields are rejected at load.",
          "properties": {
            "encoder": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "reviewed_by": {
              "type": "string"
            },
            "run_id": {
              "type": "string"
            }
          },
          "type": [
            "object",
            "null"
          ]
        },
        "kind": {
          "type": "string"
        },
        "source_verification": {
          "additionalProperties": false,
          "properties": {
            "corpus_citation_path": {
              "description": "Corpus provision path the module was encoded from.",
              "pattern": "^[a-z]{2,3}(?:-[a-z0-9]+)*/[a-z][a-z0-9-]*(?:/[A-Za-z0-9](?:[A-Za-z0-9 .:\\-–]*[A-Za-z0-9.:\\-–])?)+$",
              "type": "string"
            },
            "source_sha256": {
              "description": "SHA-256 hex digest of the exact provision text. Validated at load — must be 64 hex chars.",
              "pattern": "^[0-9a-fA-F]{64}$",
              "type": "string"
            },
            "upstream_source_check": {
              "additionalProperties": false,
              "properties": {
                "checked_paths": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "rationale": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                }
              },
              "required": [
                "status",
                "checked_paths",
                "rationale"
              ],
              "type": "object"
            }
          },
          "required": [
            "corpus_citation_path"
          ],
          "type": [
            "object",
            "null"
          ]
        },
        "status": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "validation": {
          "items": {
            "additionalProperties": true,
            "properties": {
              "last_run": {
                "format": "date",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "type": "string"
              },
              "oracle": {
                "type": "string"
              },
              "status": {
                "enum": [
                  "matches",
                  "mismatches",
                  "pending"
                ],
                "type": "string"
              }
            },
            "required": [
              "oracle",
              "status"
            ],
            "type": "object"
          },
          "type": [
            "array",
            "null"
          ]
        }
