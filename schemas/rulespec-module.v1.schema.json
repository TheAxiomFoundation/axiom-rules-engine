        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "currency"
                }
              }
            },
            "then": {
              "required": [
                "minor_units"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "custom"
                }
              }
            },
            "then": {
              "required": [
                "label"
              ]
            }
          }
        ],
