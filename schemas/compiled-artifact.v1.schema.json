        "fast_path"
      ],
      "type": "object"
    },
    "DTypeSpec": {
      "description": "Output data type. Canonical: judgment, bool, integer, decimal, text, date. Aliases (accepted, but not emitted): PascalCase forms and Money/money/Rate/rate for decimal.",
