{
  "$defs": {
    "ComparisonOpSpec": {
      "enum": [
        "lt",
        "lte",
        "gt",
        "gte",
        "eq",
        "ne"
      ],
      "type": "string"
    },
    "CompiledProgramMetadata": {
      "properties": {
