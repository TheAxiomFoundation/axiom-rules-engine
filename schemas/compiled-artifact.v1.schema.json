        "judgment",
        "Judgment",
        "bool",
        "Bool",
        "Boolean",
        "boolean",
        "integer",
        "Integer",
        "decimal",
        "Decimal",
        "Money",
        "money",
        "Rate",
        "rate",
        "text",
        "Text",
        "date",
        "Date"
      ],
      "type": "string"
    },
    "DerivedSpec": {
      "oneOf": [
        {
          "properties": {
            "expr": {
              "$ref": "#/$defs/ScalarExprSpec"
            },
            "semantics": {
              "const": "scalar",
              "type": "string"
            }
          },
          "required": [
            "semantics",
            "expr"
          ],
          "type": "object"
        },
        {
          "properties": {
            "expr": {
              "$ref": "#/$defs/JudgmentExprSpec"
            },
            "semantics": {
              "const": "judgment",
              "type": "string"
            }
